<UserControl x:Class="WpfControls.HelpControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    Width="860" Height="620">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <wv2:WebView2 x:Name="webView" Grid.Row="0"/>

        <TextBlock x:Name="errorText" Grid.Row="0"
            Margin="24" TextWrapping="Wrap" Foreground="#C00"
            Visibility="Collapsed"/>

        <Border Grid.Row="1" BorderBrush="#DDD" BorderThickness="0,1,0,0" Padding="8">
            <Button HorizontalAlignment="Right" Width="80" Click="Close_Click">Close</Button>
        </Border>
    </Grid>
</UserControl>
