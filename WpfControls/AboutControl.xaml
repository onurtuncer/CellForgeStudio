<UserControl x:Class="WpfControls.AboutControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="400" Height="240">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" FontSize="20" FontWeight="SemiBold" Text="Studio"/>
        <Border Grid.Row="1" Height="1" Background="#DDD" Margin="0,8,0,8"/>
        <TextBlock Grid.Row="2" Text="Version 0.1.0"/>
        <TextBlock Grid.Row="4" TextWrapping="Wrap" Margin="0,8,0,8">This is a minimal About dialog implemented using WPF hosted from native code via HwndSource.</TextBlock>
        <Button Grid.Row="5" HorizontalAlignment="Right" Width="80" Click="Close_Click">Close</Button>
    </Grid>
</UserControl>